# ============================================================
# SUPABASE
# ============================================================
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key   # Edge Functions 전용 (앱에 노출 금지)

# ============================================================
# EXPO (EAS Build / Push Notification)
# ============================================================
EXPO_PUBLIC_PROJECT_ID=your-expo-project-id   # eas.json 또는 Expo 대시보드에서 확인

# ============================================================
# 오픈뱅킹 API (금융결제원)
# https://openbanking.or.kr → 개발자센터 → 앱 등록
# ============================================================
OPEN_BANKING_CLIENT_ID=your-openbanking-client-id
OPEN_BANKING_CLIENT_SECRET=your-openbanking-client-secret
OPEN_BANKING_REDIRECT_URI=oorizib://openbanking/callback    # app.config.ts scheme과 일치

# ============================================================
# 한국투자증권 (KIS) OpenAPI
# https://apiportal.koreainvestment.com → 앱 등록 후 발급
# ============================================================
KIS_APP_KEY=your-kis-app-key
KIS_APP_SECRET=your-kis-app-secret
KIS_ACCOUNT_NO=your-account-number        # 예: 12345678-01
# KIS_MOCK=true                           # 모의투자 여부 (true=모의, false=실전)

# ============================================================
# 카카오 (위치 기능 - 선택사항)
# https://developers.kakao.com → 앱 등록
# ============================================================
# EXPO_PUBLIC_KAKAO_NATIVE_APP_KEY=your-kakao-native-app-key
# KAKAO_REST_API_KEY=your-kakao-rest-api-key
